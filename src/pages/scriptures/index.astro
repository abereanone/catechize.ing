---
import Main from "@/layouts/Main.astro";
import { listScriptureBookGroups } from "@/lib/scriptures";
import { siteSettings } from "@/config/siteSettings";

const bookGroups = listScriptureBookGroups();
const oldTestamentCodes = new Set([
  "gen", "exo", "lev", "num", "deu", "jos", "jdg", "rut", "1sa", "2sa", "1ki", "2ki", "1ch",
  "2ch", "ezr", "neh", "est", "job", "psa", "pro", "ecc", "sng", "isa", "jer", "lam", "ezk",
  "dan", "hos", "jol", "amo", "oba", "jon", "mic", "nah", "hab", "zep", "hag", "zec", "mal",
]);
const oldTestamentGroups = bookGroups.filter((group) => oldTestamentCodes.has(group.bookCode));
const newTestamentGroups = bookGroups.filter((group) => !oldTestamentCodes.has(group.bookCode));
const siteName = siteSettings.branding.siteName;
---

<Main title={`Scripture Index | ${siteName}`}>
  <section class="card-panel" id="scripture-index-top">
    <h1>Scripture Index</h1>
    <p>Browse the scripture references cited in proof sections and see which questions use them.</p>

    {bookGroups.length ? (
      <>
        <div class="scripture-testament-picker" aria-label="Choose testament">
          <button type="button" class="scripture-testament-button" data-testament-button data-testament-target="ot">
            Old Testament
          </button>
          <button type="button" class="scripture-testament-button" data-testament-button data-testament-target="nt">
            New Testament
          </button>
        </div>
        <label class="scripture-filter">
          <span class="scripture-filter-label">Filter references</span>
          <input
            type="search"
            class="scripture-filter-input"
            placeholder="Search references, e.g. Exodus 1 or ex 1"
            data-scripture-filter
          />
        </label>
        <div class="scripture-empty-state" data-testament-empty>
          <p>Select <strong>Old Testament</strong> or <strong>New Testament</strong> to browse the scripture index.</p>
        </div>
        <div class="scripture-search-results" data-search-results hidden>
          <div class="scripture-book-groups" data-search-groups>
            {bookGroups.map((group) => (
              <section class="scripture-book-group" data-search-group data-book-code={group.bookCode}>
                <header class="scripture-book-header">
                  <h2>{group.bookName}</h2>
                  <p>{group.entries.length === 1 ? "1 reference" : `${group.entries.length} references`}</p>
                </header>
                <ul class="scripture-grid">
                  {group.entries.map((entry) => (
                    <li
                      data-search-item
                      data-scripture-text={entry.searchText}
                      data-book-code={entry.bookCode}
                      data-book-search={entry.bookSearchText}
                      data-reference-search={entry.referencePart}
                    >
                      <a class="scripture-card card-panel" href={`/scriptures/${entry.slug}`}>
                        <span class="scripture-reference">{entry.reference}</span>
                        <span class="scripture-count">
                          {entry.questionCount === 1 ? "1 question" : `${entry.questionCount} questions`}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            ))}
          </div>
        </div>
        <div class="scripture-testament-panel" data-testament-panel="ot" hidden>
          <nav class="scripture-book-jump" aria-label="Jump to Old Testament book">
            {oldTestamentGroups.map((group) => (
              <a href={`#book-${group.bookCode}`} data-scripture-jump-link data-book-code={group.bookCode}>
                {group.bookName}
              </a>
            ))}
          </nav>
          <div class="scripture-book-groups" data-scripture-groups="ot">
            {oldTestamentGroups.map((group) => (
              <section class="scripture-book-group" data-scripture-group data-testament="ot" id={`book-${group.bookCode}`}>
                <header class="scripture-book-header">
                  <h2>{group.bookName}</h2>
                  <p>{group.entries.length === 1 ? "1 reference" : `${group.entries.length} references`}</p>
                </header>
                <ul class="scripture-grid">
                  {group.entries.map((entry) => (
                    <li data-scripture-item data-scripture-text={entry.searchText}>
                      <a class="scripture-card card-panel" href={`/scriptures/${entry.slug}`}>
                        <span class="scripture-reference">{entry.reference}</span>
                        <span class="scripture-count">
                          {entry.questionCount === 1 ? "1 question" : `${entry.questionCount} questions`}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
                <p class="scripture-back-top">
                  <a href="#scripture-index-top">Back to top</a>
                </p>
              </section>
            ))}
          </div>
        </div>
        <div class="scripture-testament-panel" data-testament-panel="nt" hidden>
          <nav class="scripture-book-jump" aria-label="Jump to New Testament book">
            {newTestamentGroups.map((group) => (
              <a href={`#book-${group.bookCode}`} data-scripture-jump-link data-book-code={group.bookCode}>
                {group.bookName}
              </a>
            ))}
          </nav>
          <div class="scripture-book-groups" data-scripture-groups="nt">
            {newTestamentGroups.map((group) => (
              <section class="scripture-book-group" data-scripture-group data-testament="nt" id={`book-${group.bookCode}`}>
                <header class="scripture-book-header">
                  <h2>{group.bookName}</h2>
                  <p>{group.entries.length === 1 ? "1 reference" : `${group.entries.length} references`}</p>
                </header>
                <ul class="scripture-grid">
                  {group.entries.map((entry) => (
                    <li data-scripture-item data-scripture-text={entry.searchText}>
                      <a class="scripture-card card-panel" href={`/scriptures/${entry.slug}`}>
                        <span class="scripture-reference">{entry.reference}</span>
                        <span class="scripture-count">
                          {entry.questionCount === 1 ? "1 question" : `${entry.questionCount} questions`}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
                <p class="scripture-back-top">
                  <a href="#scripture-index-top">Back to top</a>
                </p>
              </section>
            ))}
          </div>
        </div>
      </>
    ) : (
      <p><em>No scripture references are indexed yet.</em></p>
    )}
  </section>

  <script type="module" is:inline>
    const input = document.querySelector("[data-scripture-filter]");
    const browseItems = [...document.querySelectorAll("[data-scripture-item]")];
    const browseGroups = [...document.querySelectorAll("[data-scripture-group]")];
    const searchResults = document.querySelector("[data-search-results]");
    const searchItems = [...document.querySelectorAll("[data-search-item]")];
    const searchGroups = [...document.querySelectorAll("[data-search-group]")];
    const buttons = [...document.querySelectorAll("[data-testament-button]")];
    const panels = [...document.querySelectorAll("[data-testament-panel]")];
    const jumpLinks = [...document.querySelectorAll("[data-scripture-jump-link]")];
    const emptyState = document.querySelector("[data-testament-empty]");
    const hashLinks = [...document.querySelectorAll('a[href^="#"]')];
    let activeTestament = null;
    let browseTestament = null;
    const singleChapterBooks = new Set(["oba", "phm", "2jn", "3jn", "jud"]);

    const normalizeSearchValue = (value) =>
      value
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, " ")
        .trim();

    const parseBookAliases = (value) =>
      value
        .split("|")
        .map((alias) => normalizeSearchValue(alias))
        .filter(Boolean)
        .map((alias) => alias.split(/\s+/).filter(Boolean));

    const findMatchedAliasLength = (queryTokens, aliasTokenSets) => {
      let matchedLength = 0;

      aliasTokenSets.forEach((aliasTokens) => {
        if (aliasTokens.length > queryTokens.length) {
          return;
        }

        const matches = aliasTokens.every((token, index) => queryTokens[index] === token);
        if (matches) {
          matchedLength = Math.max(matchedLength, aliasTokens.length);
        }
      });

      return matchedLength;
    };

    const parseReferenceQuery = (tokens, isSingleChapterBook) => {
      if (!tokens.length) {
        return null;
      }

      const numbers = tokens
        .map((token) => Number.parseInt(token, 10))
        .filter((value) => Number.isFinite(value));

      if (!numbers.length) {
        return null;
      }

      if (numbers.length === 1) {
        if (isSingleChapterBook) {
          return { chapter: 1, verse: numbers[0] };
        }
        return { chapter: numbers[0], verse: null };
      }

      return { chapter: numbers[0], verse: numbers[1] };
    };

    const parseReferenceSegment = (value, isSingleChapterBook) => {
      const segment = value.trim();
      if (!segment) {
        return null;
      }

      let match = segment.match(/^(\d+)$/);
      if (match) {
        const number = Number.parseInt(match[1], 10);
        if (isSingleChapterBook) {
          return {
            startChapter: 1,
            startVerse: number,
            endChapter: 1,
            endVerse: number,
          };
        }
        const chapter = number;
        return {
          startChapter: chapter,
          startVerse: 1,
          endChapter: chapter,
          endVerse: Number.MAX_SAFE_INTEGER,
        };
      }

      match = segment.match(/^(\d+):(\d+)$/);
      if (match) {
        const chapter = Number.parseInt(match[1], 10);
        const verse = Number.parseInt(match[2], 10);
        return {
          startChapter: chapter,
          startVerse: verse,
          endChapter: chapter,
          endVerse: verse,
        };
      }

      match = segment.match(/^(\d+):(\d+)-(\d+)$/);
      if (match) {
        const chapter = Number.parseInt(match[1], 10);
        const startVerse = Number.parseInt(match[2], 10);
        const endVerse = Number.parseInt(match[3], 10);
        return {
          startChapter: chapter,
          startVerse,
          endChapter: chapter,
          endVerse,
        };
      }

      match = segment.match(/^(\d+)-(\d+)$/);
      if (match && isSingleChapterBook) {
        return {
          startChapter: 1,
          startVerse: Number.parseInt(match[1], 10),
          endChapter: 1,
          endVerse: Number.parseInt(match[2], 10),
        };
      }

      match = segment.match(/^(\d+):(\d+)-(\d+):(\d+)$/);
      if (match) {
        return {
          startChapter: Number.parseInt(match[1], 10),
          startVerse: Number.parseInt(match[2], 10),
          endChapter: Number.parseInt(match[3], 10),
          endVerse: Number.parseInt(match[4], 10),
        };
      }

      return null;
    };

    const matchesReferenceQuery = (referencePart, queryReference, isSingleChapterBook) => {
      if (!queryReference) {
        return true;
      }

      const segments = referencePart
        .split(",")
        .map((segment) => parseReferenceSegment(segment, isSingleChapterBook))
        .filter(Boolean);

      if (!segments.length) {
        return false;
      }

      return segments.some((segment) => {
        if (queryReference.verse == null) {
          return queryReference.chapter >= segment.startChapter && queryReference.chapter <= segment.endChapter;
        }

        if (queryReference.chapter < segment.startChapter || queryReference.chapter > segment.endChapter) {
          return false;
        }

        if (segment.startChapter === segment.endChapter) {
          return queryReference.chapter === segment.startChapter
            && queryReference.verse >= segment.startVerse
            && queryReference.verse <= segment.endVerse;
        }

        if (queryReference.chapter === segment.startChapter) {
          return queryReference.verse >= segment.startVerse;
        }

        if (queryReference.chapter === segment.endChapter) {
          return queryReference.verse <= segment.endVerse;
        }

        return queryReference.chapter > segment.startChapter && queryReference.chapter < segment.endChapter;
      });
    };

    const scrollWithOffset = (target) => {
      if (!target) {
        return;
      }

      const header = document.querySelector(".navbar");
      const headerHeight = header ? header.getBoundingClientRect().height : 0;
      const targetTop = window.scrollY + target.getBoundingClientRect().top - headerHeight - 16;

      window.scrollTo({
        top: Math.max(targetTop, 0),
        behavior: "smooth",
      });
    };

    const syncTestament = (target) => {
      activeTestament = target;
      browseTestament = target;
      if (searchResults) {
        searchResults.hidden = true;
      }
      buttons.forEach((button) => {
        const isActive = button.getAttribute("data-testament-target") === target;
        button.classList.toggle("is-active", isActive);
        button.setAttribute("aria-pressed", String(isActive));
      });
      panels.forEach((panel) => {
        panel.hidden = panel.getAttribute("data-testament-panel") !== target;
      });
      if (emptyState) {
        emptyState.hidden = Boolean(target);
      }
    };

    const syncSearchMode = (hasQuery) => {
      if (!hasQuery) {
        activeTestament = browseTestament;
        buttons.forEach((button) => {
          const isActive = button.getAttribute("data-testament-target") === activeTestament;
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-pressed", String(isActive));
        });
        return;
      }

      activeTestament = null;
      browseTestament = null;
      buttons.forEach((button) => {
        button.classList.remove("is-active");
        button.setAttribute("aria-pressed", "false");
      });
    };

    const applyFilter = () => {
      const query = input ? input.value.trim().toLowerCase() : "";
      const hasQuery = query.length > 0;
      const queryTokens = hasQuery ? normalizeSearchValue(query).split(/\s+/).filter(Boolean) : [];
      syncSearchMode(hasQuery);

      searchItems.forEach((item) => {
        const aliasTokenSets = parseBookAliases(item.getAttribute("data-book-search") || "");
        const matchedAliasLength = findMatchedAliasLength(queryTokens, aliasTokenSets);
        const hasAlphaQuery = queryTokens.some((token) => /[a-z]/.test(token));

        if (hasAlphaQuery && matchedAliasLength === 0) {
          item.hidden = hasQuery;
          return;
        }

        const remainingTokens = matchedAliasLength > 0 ? queryTokens.slice(matchedAliasLength) : queryTokens;
        const bookCode = String(item.getAttribute("data-book-code") || "");
        const isSingleChapterBook = singleChapterBooks.has(bookCode);
        const queryReference = parseReferenceQuery(remainingTokens, isSingleChapterBook);
        const referencePart = String(item.getAttribute("data-reference-search") || "").trim();
        const matchesQuery = hasQuery ? matchesReferenceQuery(referencePart, queryReference, isSingleChapterBook) : true;
        item.hidden = hasQuery && !matchesQuery;
      });

      searchGroups.forEach((group) => {
        const groupItems = [...group.querySelectorAll("[data-search-item]")];
        const visibleItems = groupItems.filter((item) => !item.hidden);
        group.classList.toggle("is-hidden", !hasQuery || visibleItems.length === 0);
      });

      browseItems.forEach((item) => {
        item.hidden = false;
      });

      browseGroups.forEach((group) => {
        const groupItems = [...group.querySelectorAll("[data-scripture-item]")];
        const visibleItems = groupItems.filter((item) => !item.hidden);
        const testamentMatches = hasQuery
          ? true
          : !activeTestament || group.getAttribute("data-testament") === activeTestament;
        group.classList.toggle("is-hidden", !testamentMatches || visibleItems.length === 0);
      });

      jumpLinks.forEach((link) => {
        const code = link.getAttribute("data-book-code");
        if (!code) {
          return;
        }
        const group = document.querySelector(`[data-scripture-group][id="book-${code}"]`);
        link.hidden = !group || group.classList.contains("is-hidden");
      });

      panels.forEach((panel) => {
        const jumpNav = panel.querySelector(".scripture-book-jump");
        if (jumpNav) {
          const visibleLinks = [...jumpNav.querySelectorAll("[data-scripture-jump-link]")].filter((link) => !link.hidden);
          jumpNav.hidden = hasQuery || visibleLinks.length === 0;
        }

        if (hasQuery) {
          panel.hidden = true;
        } else {
          panel.hidden = panel.getAttribute("data-testament-panel") !== activeTestament;
        }
      });

      if (searchResults) {
        const visibleSearchGroups = searchGroups.filter((group) => !group.classList.contains("is-hidden"));
        searchResults.hidden = !hasQuery || visibleSearchGroups.length === 0;
      }

      if (emptyState) {
        emptyState.hidden = hasQuery || Boolean(activeTestament);
      }
    };

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        syncTestament(button.getAttribute("data-testament-target"));
        applyFilter();
      });
    });

    hashLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        const href = link.getAttribute("href");
        if (!href || href === "#") {
          return;
        }

        const target = document.querySelector(href);
        if (!target) {
          return;
        }

        event.preventDefault();
        history.replaceState(null, "", href);
        scrollWithOffset(target);
      });
    });

    if (input && searchItems.length) {
      input.addEventListener("input", () => {
        applyFilter();
      });
    }
  </script>

  <style>
    .scripture-testament-picker {
      display: flex;
      flex-wrap: wrap;
      gap: 0.6rem;
      margin: 1rem 0;
    }

    .scripture-testament-button {
      padding: 0.45rem 0.95rem;
      border-radius: var(--radius-pill);
      border: 1px solid var(--chip-border);
      background: var(--chip-bg);
      color: var(--color-text);
      font: inherit;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      transition: var(--transition-border-bg);
    }

    .scripture-testament-button.is-active {
      border-color: var(--chip-hover-border);
      background: var(--chip-hover-bg);
    }

    .scripture-testament-button:hover,
    .scripture-testament-button:focus-visible {
      border-color: var(--chip-hover-border);
      background: var(--chip-hover-bg);
      outline: none;
    }

    .scripture-empty-state {
      margin: 1rem 0 1.5rem;
      color: var(--color-text-soft);
    }

    .scripture-testament-panel[hidden] {
      display: none;
    }

    .scripture-book-group.is-hidden {
      display: none;
    }

    .scripture-book-jump {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem;
      margin: 1rem 0 1.25rem;
    }

    .scripture-book-jump a {
      display: inline-block;
      padding: 0.35rem 0.75rem;
      border-radius: var(--radius-pill);
      border: 1px solid var(--chip-border);
      text-decoration: none;
      color: inherit;
      background: var(--chip-bg);
      font-size: 0.9rem;
      transition: var(--transition-border-bg);
    }

    .scripture-book-jump a:hover,
    .scripture-book-jump a:focus-visible {
      background: var(--chip-hover-bg);
      border-color: var(--chip-hover-border);
    }

    .scripture-filter {
      display: block;
      margin: 0 0 1.25rem;
    }

    .scripture-filter-label {
      display: block;
      margin-bottom: 0.4rem;
      font-weight: 600;
    }

    .scripture-filter-input {
      width: 100%;
      max-width: 420px;
      padding: 0.75rem 0.9rem;
      border-radius: 0.85rem;
      border: 1px solid var(--surface-border);
      background: var(--surface-panel);
      color: var(--color-text);
    }

    .scripture-book-groups {
      display: grid;
      gap: 1.5rem;
    }

    .scripture-book-group {
      display: grid;
      gap: 0.85rem;
    }

    .scripture-book-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .scripture-book-header h2,
    .scripture-book-header p {
      margin: 0;
    }

    .scripture-book-header p {
      color: var(--color-text-soft);
    }

    .scripture-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.9rem;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .scripture-card {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      text-decoration: none;
    }

    .scripture-reference {
      font-weight: 700;
      color: var(--color-text);
    }

    .scripture-count {
      color: var(--color-text-soft);
    }

    .scripture-back-top {
      margin: 0;
    }

    .scripture-back-top a {
      text-decoration: none;
      font-weight: 600;
    }

    @media (max-width: 640px) {
      .scripture-book-jump {
        margin-top: 0.75rem;
      }
    }
  </style>
</Main>
